// Part 7 — structs, enums, match

// Structs
struct Point { x, y }
let p = Point { x: 3, y: 4 }
print p["x"]
print p["y"]

p["x"] = 99
print p["x"]

// Struct passed to function
fn dist(a, b) {
    let dx = a["x"] - b["x"]
    let dy = a["y"] - b["y"]
    dx * dx + dy * dy
}
let q = Point { x: 0, y: 0 }
print dist(p, q)

// FieldAccess syntax (p.x)
let p2 = Point { x: 10, y: 20 }
print p2.x
print p2.y

p2.x = 55
print p2.x

// Enums (no payload)
enum Color { Red, Green, Blue }
let c = Color.Red
print c
let g = Color.Green
print g

// Match on enum (no payload)
fn color_name(col) {
    match col {
        Color.Red   -> "red"
        Color.Green -> "green"
        Color.Blue  -> "blue"
        _           -> "unknown"
    }
}
print color_name(Color.Red)
print color_name(Color.Blue)

// Match on integer
fn classify(n) {
    match n {
        0 -> "zero"
        1 -> "one"
        2 -> "two"
        _ -> "many"
    }
}
print classify(0)
print classify(2)
print classify(9)

// Match on string
fn greet(lang) {
    match lang {
        "en" -> "hello"
        "es" -> "hola"
        "fr" -> "bonjour"
        _    -> "hi"
    }
}
print greet("es")
print greet("fr")
print greet("de")

// Enums with payload
enum Shape { Circle(r), Rect(w, h) }
let s1 = Shape.Circle(7)
let s2 = Shape.Rect(3, 4)
print s1
print s2

// Match on enum with payload
fn area(s) {
    match s {
        Shape.Circle(r) -> r * r
        Shape.Rect(w, h) -> w * h
    }
}
print area(Shape.Circle(5))
print area(Shape.Rect(6, 7))

// Match as expression assigned to variable
let n = 3
let word = match n {
    1 -> "one"
    2 -> "two"
    3 -> "three"
    _ -> "other"
}
print word
