print "--- basic throw and catch ---"
try {
    throw "something went wrong"
} catch e {
    print "caught: {e}"
}

print "--- throw a number ---"
try {
    throw 42
} catch e {
    print "caught number: {e}"
}

print "--- throw a hashmap ---"
try {
    throw {"code": 404, "msg": "not found"}
} catch e {
    print "code: {e["code"]}"
    print "msg: {e["msg"]}"
}

print "--- throw inside a function ---"
fn divide(a, b) {
    if b == 0 { throw "division by zero" }
    a / b
}
try {
    print divide(10, 2)
    print divide(10, 0)
    print "never reached"
} catch e {
    print "caught: {e}"
}

print "--- throw inside a loop ---"
try {
    for i in 0..5 {
        if i == 3 { throw "hit 3" }
        print i
    }
} catch e {
    print "loop threw: {e}"
}

print "--- nested try blocks ---"
try {
    try {
        throw "inner error"
    } catch e {
        print "inner caught: {e}"
        throw "rethrown"
    }
} catch e {
    print "outer caught: {e}"
}

print "--- try with no throw ---"
try {
    let x = 1 + 1
    print "no error: {x}"
} catch e {
    print "should not reach here"
}

print "--- runtime error caught by try ---"
try {
    int("not a number")
} catch e {
    print "runtime error caught: {e}"
}

print "--- throw inside nested function ---"
fn outer() {
    fn inner() {
        throw "from inner"
    }
    inner()
}
try {
    outer()
} catch e {
    print "caught from nested fn: {e}"
}

print "--- catch variable is scoped ---"
let e = "original"
try {
    throw "new value"
} catch e {
    print "inside catch: {e}"
}
print "after catch: {e}"

print "--- throw array ---"
try {
    throw [1, 2, 3]
} catch e {
    print "caught array: {e}"
    print "first element: {e[0]}"
}
