// arrays
let arr = [10, 20, 30]
print arr[0]
print arr[1]
print arr[2]
print arr[-1]
print len(arr)

let arr2 = push(arr, 40)
print arr2[3]
print len(arr2)

arr[0] = 99
print arr[0]

// nested array
let grid = [[1, 2], [3, 4]]
print grid[0][0]
print grid[1][1]

// hashmaps
let m = {"name": "Alice", "age": 30}
print m["name"]
print m["age"]
print m["missing"]
print len(m)

m["age"] = 31
print m["age"]

// functions using arrays
fn sum_arr(arr) {
    let total = 0
    let i = 0
    while i < len(arr) {
        total = total + arr[i]
        i = i + 1
    }
    total
}

print sum_arr([1, 2, 3, 4, 5])

fn make_range(n) {
    let result = []
    let i = 0
    while i < n {
        result = push(result, i)
        i = i + 1
    }
    result
}

let r = make_range(5)
print r[0]
print r[4]
print len(r)
