// ----------------------------------------
// 17. Variadic functions
// ----------------------------------------
print ""
print "--- variadic ---"
fn log(label, items...) {
    printn "{label}: "
    for item in items {
        printn "{item} "
    }
    print ""
}
log("nums", 1, 2, 3, 4, 5)      // nums: 1 2 3 4 5
log("words", "hi", "hello")     // words: hi hello

