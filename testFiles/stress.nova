// ----------------------------------------
// 19. Complex combined example
// ----------------------------------------
print ""
print "--- combined: leaderboard ---"
let players = ["Alice", "Bob", "Charlie", "Diana", "Eve"]
let scores  = [88, 72, 95, 61, 79]

let board = {}
for [player, score] in zip(players, scores) {
    board = setKey(board, player, score)
}

fn rank(score) {
    match score {
        90..101 => "S"
        70..90  => "A"
        50..70  => "B"
        _       => "C"
    }
}

let sorted_scores = sort(scores)
let sorted_scores = reverse(sorted_scores)

print "Leaderboard:"
for [player, score] in zip(players, scores) {
    print "  {player}: {score} ({rank(score)})"
}
print "Top score: {max(scores)}"
print "Average:   {round(sum(scores) / len(scores), 1)}"
print "Passing (>=70): {count(scores, (s) -> s >= 70)}"

print ""
print "ALL STRESS TESTS PASSED"
