print "--- for loop over a string ---"
try {
    for ch in "hello" {
        print ch
    }
} catch e {
    print "error: {e}"
}

print "--- calling a non-function variable ---"
try {
    let x = 42
    x(1, 2)
} catch e {
    print "caught: {e}"
}

print "--- break in nested loops ---"
for i in 0..3 {
    for j in 0..3 {
        if j == 1 { break }
        print "{i},{j}"
    }
}

print "--- continue in nested loops ---"
for i in 0..3 {
    for j in 0..3 {
        if j == 1 { continue }
        print "{i},{j}"
    }
}

print "--- break in outer loop ---"
for i in 0..5 {
    if i == 3 { break }
    for j in 0..3 {
        print "{i},{j}"
    }
}

print "--- arrays of hashmaps ---"
let users = [
    {"name": "Alice", "age": 30},
    {"name": "Bob",   "age": 25},
    {"name": "Carol", "age": 35}
]
for user in users {
    print "{user["name"]} is {user["age"]}"
}
print users[1]["name"]

print "--- hashmaps of arrays ---"
let data = {
    "scores": [10, 20, 30],
    "names":  ["Alice", "Bob"]
}
print data["scores"][1]
print data["names"][0]
print len(data["scores"])

print "--- modifying hashmap inside loop ---"
let counts = {}
let words = ["a", "b", "a", "c", "b", "a"]
for w in words {
    if hasKey(counts, w) {
        counts = setKey(counts, w, counts[w] + 1)
    } else {
        counts = setKey(counts, w, 1)
    }
}
print counts["a"]
print counts["b"]
print counts["c"]

print "--- null coalescing chain ---"
let a = nil
let b = nil
let c = "found"
print a ?? b ?? c
print a ?? "default"
print "hello" ?? "default"

print "--- null coalescing with function result ---"
fn maybe_nil(x) {
    if x > 0 { return x }
    return nil
}
print maybe_nil(-1) ?? 99
print maybe_nil(5)  ?? 99

print "--- array of arrays ---"
let matrix = [[1,2,3],[4,5,6],[7,8,9]]
print matrix[1][1]
print matrix[0][2]
print matrix[2][0]

print "--- empty hashmap operations ---"
let m = {}
print hasKey(m, "x")
print keys(m)
print values(m)

print "--- reassign to different type ---"
let val = 42
val = "now a string"
print val
val = true
print val
val = [1, 2, 3]
print val
