// Phase 8 Part 2 — VM control flow test
// Expected outputs listed after each section

// ── 1. if / else ─────────────────────────────────────────────────
if true  { print "a" }              // a
if false { print "x" }              // (skipped)
if 5 > 3 { print "b" } else { print "x" }   // b
if 5 < 3 { print "x" } else { print "c" }   // c

let n = 7
if n > 0 {
    if n > 5 { print "d" } else { print "x" }   // d
}

// ── 2. while ─────────────────────────────────────────────────────
let i = 0
while i < 4 { i = i + 1 }
print i     // 4

let sum = 0
let j = 1
while j <= 5 { sum = sum + j   j = j + 1 }
print sum   // 15

// ── 3. for range ─────────────────────────────────────────────────
let total = 0
for k in 0..5 { total = total + k }
print total     // 10

let count = 0
for m in 0..100 { count = count + 1 }
print count     // 100

// ── 4. break ─────────────────────────────────────────────────────
let last = 0
for i in 0..20 {
    if i == 5 { break }
    last = i
}
print last      // 4

let found = 0
let w = 0
while w < 100 {
    if w == 13 { found = w   break }
    w = w + 1
}
print found     // 13

// ── 5. continue ──────────────────────────────────────────────────
let odd_sum = 0
for i in 1..11 {
    if i % 2 == 0 { continue }
    odd_sum = odd_sum + i
}
print odd_sum   // 25  (1+3+5+7+9)

let evens = 0
let e = 0
while e < 10 {
    e = e + 1
    if e % 2 != 0 { continue }
    evens = evens + 1
}
print evens     // 5

// ── 6. nested for loops ──────────────────────────────────────────
let cells = 0
for r in 0..4 {
    for c in 0..4 {
        cells = cells + 1
    }
}
print cells     // 16

// ── 7. fibonacci ─────────────────────────────────────────────────
let a = 0
let b = 1
for step in 0..10 {
    let tmp = b
    b = a + b
    a = tmp
}
print a         // 55

// ── 8. while + break ─────────────────────────────────────────────
let p = 1
while p < 1000 {
    p = p * 2
    if p > 100 { break }
}
print p         // 128
