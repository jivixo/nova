// Items 1 + 2: for loops, break, continue in LLVM backend

// Range loop basic
let s = 0
for i in 0..5 {
    s = s + i
}
print s          // 10

// Range loop with function
fn sum_range(n) {
    let acc = 0
    for i in 0..n {
        acc = acc + i
    }
    acc
}
print sum_range(10)   // 45
print sum_range(100)  // 4950

// For-in array
let arr = [10, 20, 30, 40, 50]
let total = 0
for x in arr {
    total = total + x
}
print total      // 150

// For-enumerate
let pairs = 0
for i, v in [5, 6, 7] {
    pairs = pairs + i + v
}
print pairs      // (0+5) + (1+6) + (2+7) = 21

// For-destructure
let coord_sum = 0
for [dx, dy] in [[1, 2], [3, 4], [5, 6]] {
    coord_sum = coord_sum + dx + dy
}
print coord_sum  // 21

// break
let n = 0
for i in 0..100 {
    if i == 5 {
        break
    }
    n = n + 1
}
print n          // 5

// continue
let evens = 0
for i in 0..10 {
    if i % 2 != 0 {
        continue
    }
    evens = evens + i
}
print evens      // 0+2+4+6+8 = 20

// break in while
let w = 0
let j = 0
while j < 100 {
    if j == 7 {
        break
    }
    w = w + 1
    j = j + 1
}
print w          // 7

// continue in while
let odd_sum = 0
let k = 0
while k < 10 {
    k = k + 1
    if k % 2 == 0 {
        continue
    }
    odd_sum = odd_sum + k
}
print odd_sum    // 1+3+5+7+9 = 25

// Nested loops
let grid = 0
for r in 0..3 {
    for c in 0..3 {
        grid = grid + 1
    }
}
print grid       // 9
