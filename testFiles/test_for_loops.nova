// Group 1 final: for loops + break/continue

// Basic range loop
for i in 0..5 {
    print i
}
// 0 1 2 3 4

// Range with non-zero start
for i in 3..7 {
    print i
}
// 3 4 5 6

// for-in-array
let fruits = ["apple", "banana", "cherry"]
for f in fruits {
    print f
}
// apple banana cherry

// for-enumerate
for i, v in [10, 20, 30] {
    print i
    print v
}
// 0 10 1 20 2 30

// for-destructure
let pairs = [[1, 2], [3, 4], [5, 6]]
for [a, b] in pairs {
    print a + b
}
// 3 7 11

// break
for i in 0..10 {
    if i == 3 {
        break
    }
    print i
}
// 0 1 2

// continue
for i in 0..6 {
    if i == 2 {
        continue
    }
    if i == 4 {
        continue
    }
    print i
}
// 0 1 3 5

// nested for loops
for i in 0..3 {
    for j in 0..3 {
        print i + j
    }
}
// 0 1 2 1 2 3 2 3 4

// break in nested loop (only breaks inner)
for i in 0..3 {
    for j in 0..5 {
        if j == 2 {
            break
        }
        print j
    }
    print i
}
// 0 1 0 0 1 1 0 1 2

// accumulator with for loop
let sum = 0
for i in 1..6 {
    sum = sum + i
}
print sum
// 15

// for over empty array
let empty = []
for x in empty {
    print x
}
// (nothing)

print "done"
