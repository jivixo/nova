// Phase 8 Part 3 — VM built-in functions test

// ── 1. type conversions ──────────────────────────────────────────
print str(42)           // 42
print str(3.14)         // 3.14
print str(true)         // true
print str(nil)          // nil

print int("99")         // 99
print int(3.9)          // 3
print int(true)         // 1
print int(false)        // 0

print float(7)          // 7.0
print float("2.5")      // 2.5

print bool(0)           // false
print bool(1)           // true
print bool(nil)         // false
print bool("hi")        // true

// ── 2. type() ────────────────────────────────────────────────────
print type(42)          // int
print type(3.14)        // float
print type(true)        // bool
print type("hello")     // string
print type(nil)         // nil

// ── 3. string operations ─────────────────────────────────────────
print upper("hello")    // HELLO
print lower("WORLD")    // world
print len("nova")       // 4
print trim("  hi  ")    // hi

print contains("hello world", "world")    // true
print contains("hello world", "xyz")      // false

print startsWith("nova lang", "nova")    // true
print startsWith("nova lang", "lang")    // false

print endsWith("nova lang", "lang")      // true
print endsWith("nova lang", "nova")      // false

// ── 4. ord / chr ─────────────────────────────────────────────────
print ord("A")          // 65
print ord("a")          // 97
print chr(65)           // A
print chr(97)           // a

// ── 5. math ──────────────────────────────────────────────────────
print abs(-5)           // 5
print abs(3)            // 3
print abs(-2.5)         // 2.5

print max(3, 7)         // 7
print min(3, 7)         // 3
print max(1, 9, 4)      // 9
print min(8, 2, 5)      // 2

print sqrt(9)           // 3.0
print sqrt(2.0)         // 1.4142135623730951

print floor(3.9)        // 3
print floor(3.1)        // 3
print ceil(3.1)         // 4
print ceil(3.9)         // 4

// ── 6. combined ──────────────────────────────────────────────────
let s = "  Nova Language  "
print lower(trim(s))    // nova language
let n = int(float("3.7"))
print n                 // 3
